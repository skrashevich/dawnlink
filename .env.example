# GitHub App (create at https://github.com/settings/apps/new)
GITHUB_APP_NAME=dawnlink
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PEM_FILENAME=./private-key.pem

# Shared secret for private repo access tokens (?h=). Generate with:
# openssl rand -hex 32
APP_SECRET=

# Installation ID used for anonymous public repo access (optional but recommended)
FALLBACK_INSTALLATION_ID=

# Server
PORT=8080
URL=http://localhost:8080/
# Multiple public URLs (comma-separated). The first URL is primary for GitHub App setup.
# URL=https://dawnl.ink/,https://dawnlink.svk.app/
DATABASE_FILE=./db.sqlite

# Fallback UI language: en or ru
DEFAULT_LOCALE=en
